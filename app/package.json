"use client";

import { useState, useEffect } from "react";
import {
  MapPin,
  Wind,
  Droplets,
  Eye,
  Gauge,
  Cloud,
  Navigation,
  Calendar,
  Newspaper,
  Trophy,
  Sparkles,
  Send
} from "lucide-react";

export default function MiksAI() {
  const [weather, setWeather] = useState(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);
  const [locationStatus, setLocationStatus] = useState("requesting");
  const [news, setNews] = useState([]);
  const [sports, setSports] = useState([]);
  const [newsLoading, setNewsLoading] = useState(true);
  const [sportsLoading, setSportsLoading] = useState(true);
  const [chatInput, setChatInput] = useState("");

  useEffect(() => {
    requestLocationAndFetchWeather();
    // Simuleret data indtil API forbindes på Vercel
    setNews([
      { title: "Velkommen til MiksAI", snippet: "Dine nyheder fra EB, BT og TV2 lander her snart...", source: "MiksAI System", link: "#" }
    ]);
    setSports([
      { title: "Sports-stream klar", snippet: "Nattens resultater fra bold.dk og verden...", source: "Bold.dk", link: "#" }
    ]);
    setNewsLoading(false);
    setSportsLoading(false);
  }, []);

  const requestLocationAndFetchWeather = () => {
    setLoading(true);
    if (typeof window !== "undefined" && navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        async (position) => {
          setLocationStatus("granted");
          const { latitude, longitude } = position.coords;
          try {
            // Denne rute virker når vi deployer på Vercel med vejr-integration
            const response = await fetch(`/integrations/weather-by-city/weather/${latitude},${longitude}`);
            if (response.ok) {
              const data = await response.json();
              setWeather(data);
            }
          } catch (err) {
            console.log("Vejr-data hentes ved deployment");
          } finally {
            setLoading(false);
          }
        },
        () => {
          setLocationStatus("denied");
          setLoading(false);
        }
      );
    }
  };

  return (
    <div className="min-h-screen relative overflow-hidden font-sans bg-[#0a0520] text-white">
      {/* BAGGRUND: Neon Glow System */}
      <div className="fixed inset-0 z-0">
        <div className="absolute top-[-10%] left-[-10%] w-[70%] h-[70%] bg-[#FF1744] rounded-full blur-[120px] opacity-20 animate-pulse"></div>
        <div className="absolute bottom-[-10%] right-[-10%] w-[70%] h-[70%] bg-[#00E5FF] rounded-full blur-[120px] opacity-20 animate-pulse"></div>
      </div>

      <div className="relative z-10 p-6 max-w-2xl mx-auto pb-32">
        {/* HEADER med dit Logo */}
        <header className="mb-8 pt-4 flex items-center gap-6 border-b border-[#00E5FF]/20 pb-6">
          <img 
            src="/M_logo.jpg" 
            alt="MiksAI Logo" 
            className="w-20 h-20 rounded-2xl border-2 border-[#B721FF] shadow-[0_0_20px_rgba(183,33,255,0.5)] object-cover"
          />
          <div>
            <h1 className="text-5xl font-bold tracking-tighter neon-text">
              MIKS<span className="text-[#00E5FF]">_</span>AI
            </h1>
            <p className="text-[#00E5FF] text-[10px] tracking-[0.3em] font-medium opacity-80 mt-1 uppercase">
              Din Personlige Morgen-Hub
            </p>
          </div>
        </header>

        {/* VEJR SEKTION */}
        <section className="glass-card p-6 mb-6 border-[#FF1744]/30 shadow-[0_0_20px_rgba(255,23,68,0.1)]">
          <div className="flex justify-between items-center mb-4">
            <div className="flex items-center gap-2">
              <MapPin size={16} className="text-[#FF1744]" />
              <span className="text-xs font-bold uppercase tracking-widest">
                {weather ? weather.location.name : 'Søger din lokation...'}
              </span>
            </div>
            <button onClick={requestLocationAndFetchWeather} className="text-[10px] border border-[#00E5FF] px-2 py-1 rounded hover:bg-[#00E5FF]/20 transition-all uppercase">Opdater</button>
          </div>
          
          {weather ? (
            <div className="flex items-center justify-between">
              <div>
                <div className="text-5xl font-bold">{Math.round(weather.current.temp_c)}°C</div>
                <div className="text-xs text-[#00E5FF] uppercase mt-1">{weather.current.condition.text}</div>
              </div>
              <img src={`https:${weather.current.condition.icon}`} className="w-16 h-16 drop-shadow-[0_0_10px_rgba(0,229,255,0.5)]" alt="weather icon" />
            </div>
          ) : (
            <div className="py-4 text-center text-sm text-gray-400 italic">Vejr-data indlæses...</div>
          )}
        </section>

        {/* KALENDER SEKTION */}
        <section className="glass-card p-6 mb-6 border-[#B721FF]/30">
          <h2 className="flex items-center gap-2 text-sm font-bold mb-4 text-[#B721FF] uppercase tracking-wider">
            <Calendar size={18} /> Dagens Program
          </h2>
          <button className="w-full py-4 bg-white/5 border border-white/10 rounded-xl text-sm font-semibold flex items-center justify-center gap-2 hover:bg-white/10 transition-all">
            Log ind med Outlook
          </button>
        </section>

        {/* NYHEDER */}
        <section className="glass-card p-6 mb-6 border-[#00E5FF]/30">
          <h2 className="flex items-center gap-2 text-sm font-bold mb-4 text-[#00E5FF] uppercase tracking-wider">
            <Newspaper size={18} /> Seneste Nyheder
          </h2>
          <div className="space-y-4">
             {news.map((item, i) => (
               <div key={i} className="p-3 bg-white/5 rounded-lg border border-white/5">
                 <div className="text-xs font-bold text-[#FF1744] mb-1">{item.source}</div>
                 <div className="text-sm font-medium">{item.title}</div>
               </div>
             ))}
          </div>
        </section>

        {/* AI CHAT INPUT */}
        <div className="fixed bottom-6 left-6 right-6 max-w-2xl mx-auto z-50">
          <div className="relative">
            <input 
              type="text" 
              value={chatInput}
              onChange={(e) => setChatInput(e.target.value)}
              placeholder="Spørg MiksAI eller tilføj aftale..."
              className="w-full bg-black/80 backdrop-blur-2xl border border-[#B721FF]/50 rounded-full py-5 px-8 pr-14 text-sm focus:outline-none focus:border-[#00E5FF] shadow-[0_0_30px_rgba(183,33,255,0.2)]"
            />
            <button className="absolute right-5 top-1/2 -translate-y-1/2 text-[#00E5FF]">
              <Send size={24} />
            </button>
          </div>
        </div>
      </div>

      <style jsx global>{`
        @import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;700&display=swap');
        body { font-family: 'Rajdhani', sans-serif; }
        .glass-card {
          background: rgba(10, 5, 32, 0.7);
          backdrop-filter: blur(25px);
          border-radius: 24px;
          border: 1px solid rgba(255, 255, 255, 0.08);
        }
        .neon-text {
          text-shadow: 0 0 20px rgba(255, 23, 68, 0.6);
        }
      `}</style>
    </div>
  );
}
